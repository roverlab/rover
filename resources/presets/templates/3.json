{
  "dns_servers": [
    {
      "name": "Google",
      "type": "tls",
      "server": "8.8.8.8",
      "detour": "selector_out"
    },
    {
      "name": "Cloudflare",
      "type": "tls",
      "server": "1.1.1.1"
    },
    {
      "name": "Aliyun",
      "type": "udp",
      "server": "223.5.5.5"
    },
    {
      "name": "阿里云",
      "type": "https",
      "server": "dns.alidns.com",
      "domain_resolver": "local"
    },
    {
      "name": "腾讯云",
      "type": "https",
      "server": "doh.pub",
      "domain_resolver": "local"
    },
    {
      "name": "local",
      "type": "local"
    },
    {
      "name": "fakeip",
      "raw_data": {
        "tag": "fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
  
    }
  ],
  "dns_rules": [
    {
      "name": "🎯 国内域名解析",
      "rule_set": [
      "acl:Apple",
      "acl:ChinaDomain",
      "acl:UnBan",
      "acl:SteamCN",
      "acl:ChinaMedia",
      "acl:Download"
    ],
      "server": "Aliyun"
    },
    {
      "name": "🌏 其它域名IP伪装",
      "raw_data": {
        "server": "fakeip",
        "query_type": [
          "A",
          "AAAA"
        ]
      }
    }
  ],
  "rules": [
     {
      "name": "🏠 私有网络",
      "raw_data": {
        "ip_is_private": true,
        "outbound": "direct_out"
      }
    },
    {
      "rule_set_build_in": [
        "acl:Apple"
      ],
      "outbound": "direct_out",
      "name": "🍎 苹果服务"
    },
    {
      "rule_set_build_in": [
        "acl:ChinaDomain",
        "acl:UnBan",
        "acl:SteamCN",
        "acl:ChinaMedia",
        "acl:Download"
      ],
      "outbound": "direct_out",
      "name": "🎯 国内域名直连"
    },
    {
      "name": "🌏 国外穿墙",
      "rule_set_build_in": [
        "geosite:geolocation-!cn",
        "geosite:google",
        "geoip:google",
        "acl:ProxyGFWlist",
        "acl:ProxyMedia"
      ],
      "outbound": "selector_out"
    },
    {
      "name": "🔍 未匹配域名DNS解析",
      "raw_data": {
        "action": "resolve"
      }
    },
    {
      "name": "🎯国内IP直连",
      "rule_set_build_in": [
        "acl:ChinaIp",
        "acl:ChinaCompanyIp",
        "geoip:cn"
      ],
      "outbound": "direct_out"
    }
  ],
  "rule_unmatched_outbound": "selector_out",
  "tun": true,
  "default_dns_server": "Google"
}