{
  "dns": {
    "servers": [
      {
        "tag": "Google",
        "type": "udp",
        "server": "8.8.8.8"
      },
      {
        "tag": "阿里云",
        "type": "udp",
        "server": "223.5.5.5"
      },
      {
        "tag": "fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "name": "🎯 国内域名解析",
        "rule_set": [
        "acl:ChinaDomain",
        "acl:UnBan",
        "acl:SteamCN",
        "acl:ChinaMedia"
      ],
        "server": "阿里云"
      },
      {
        "name": "🌏 其它域名IP伪装",
        "raw_data": {
          "server": "fakeip",
          "query_type": [
            "A",
            "AAAA"
          ]
        }
      }
    ],
    "independent_cache": true
  },
  "rules": [
    {
      "name": "🔍 流量嗅探",
      "raw_data": {
        "action": "sniff"
      }
    },
    {
      "name": "🛡️ DNS 劫持",
      "raw_data": {
        "protocol": "dns",
        "action": "hijack-dns"
      }
    },
    {
      "name": "🏠 私有网络",
      "outbound": "direct",
      "raw_data": {
        "ip_is_private": true,
        "outbound": "direct"
      }
    },
    {
      "rule_set_build_in": [
        "acl:ChinaDomain",
        "acl:UnBan",
        "acl:SteamCN",
        "acl:ChinaMedia",
        "acl:Download"
      ],
      "outbound": "direct",
      "name": "🎯 国内直连（非IP）"
    },
    {
      "name": "🔍 未匹配域名DNS解析",
      "raw_data": {
        "action": "resolve"
      }
    },
    {
      "name": "🎯国内直连（IP）",
      "rule_set_build_in": [
        "acl:ChinaIp",
        "acl:ChinaCompanyIp",
        "geoip:cn"
      ],
      "outbound": "direct"
    },
    {
      "name": "🌏 国外穿墙",
      "rule_set_build_in": [
        "geosite:geolocation-!cn",
        "geosite:google",
        "geoip:google",
        "acl:ProxyGFWlist",
        "acl:ProxyMedia"
      ],
      "outbound": "currentSelected"
    }
  ],
  "rule_unmatched_outbound": "currentSelected",
  "tun": true,
  "default_dns_server": "Google"
}